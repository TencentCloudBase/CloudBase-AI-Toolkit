# 服务端口
PORT=3000

# 服务基础 URL（用于拼接授权页地址等）
BASE_URL=http://localhost:3000

# 设备码有效期（秒）
EXPIRES_IN=600

# 轮询间隔（秒）
INTERVAL=3

# ────────────────────────────────────────────────────────────
# CloudBase 管理中心环境配置
# 用于"1+N"架构中的"1"——管理中心环境
# ────────────────────────────────────────────────────────────

# 管理中心环境的完整 envId
CLOUDBASE_ENV_ID=

# 管理中心环境的 Publishable Key（前端 SDK 用）
# 获取路径：控制台 → 身份认证 → 应用管理 → Publishable Key
CLOUDBASE_PUBLISHABLE_KEY=

# 管理中心环境的地域（默认 ap-shanghai）
CLOUDBASE_REGION=ap-shanghai

# ────────────────────────────────────────────────────────────
# 腾讯云 API 密钥（用于创建用户环境和下发 API Key）
# 密钥可前往 https://console.cloud.tencent.com/cam/capi 获取
# 此密钥需要具备 tcb:CreateEnv / tcb:DescribeEnvs 等权限
# ────────────────────────────────────────────────────────────
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
# STS 临时凭证有效期（秒，默认 1800）。本次使用 API Key 方式，此项保留向下兼容
STS_TOKEN_DURATION=1800
