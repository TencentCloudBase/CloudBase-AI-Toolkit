#!/usr/bin/env node
/**
 * cloudbase-vibe-restart-preview
 *
 * Bring the Vite dev server in cwd back to a clean started state.
 * Equivalent to `cloudbase-vibe-start-preview --force`.
 *
 * Usage: any args are forwarded to start-preview, plus --force is always set.
 */

import { spawnSync } from "node:child_process";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";

const __dirname = dirname(fileURLToPath(import.meta.url));
const startBin = join(__dirname, "cloudbase-vibe-start-preview");

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  process.stdout.write([
    "cloudbase-vibe-restart-preview — stop and start Vite dev server in cwd",
    "",
    "Options:",
    "  --port <N>  forwarded to start-preview",
    "  --base <P>  forwarded to start-preview",
    "",
    "Equivalent to: cloudbase-vibe-start-preview --force <other-args>",
    "",
  ].join("\n"));
  process.exit(0);
}

// Forward all args + ensure --force is present (deduped).
const userArgs = process.argv.slice(2).filter((a) => a !== "--force" && a !== "-f");
const finalArgs = ["--force", ...userArgs];

const r = spawnSync(startBin, finalArgs, { stdio: "inherit" });
process.exit(r.status ?? 1);
