{
  "name": "cloudbase-ai-toolkit",
  "version": "1.7.3",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "check:readme-sync": "node scripts/check-readme-sync.js",
    "update:compat-baseline": "node scripts/update-compat-baseline.mjs",
    "check:compat-diff": "node scripts/diff-compat-config.mjs",
    "sync:claude-skills-mirror": "node scripts/sync-claude-skills-mirror.mjs",
    "check:claude-skills-mirror": "node scripts/sync-claude-skills-mirror.mjs --check",
    "build:mcp": "cd mcp && npm run build && cd ..",
    "build": "npm run build:mcp && npm run build:tools-json && npm run build:tools-doc && npm run build:prompts-data && npm run build:rules-sync",
    "build:tools-json": "cd mcp && npm run build && cd .. && node scripts/generate-tools-json.mjs",
    "build:tools-doc": "node scripts/generate-tools-doc.mjs",
    "build:prompts-data": "node scripts/generate-prompts-data.mjs && node scripts/generate-prompts.mjs",
    "build:rules-sync": "node scripts/build-compat-config.mjs",
    "generate:tcb-action-index": "node scripts/generate-tcb-action-index.mjs",
    "build:skill-manifest": "node scripts/build-skill-manifest.mjs",
    "sync:config": "node scripts/sync-config.mjs",
    "test:hooks": "vitest run tests/hooks/",
    "eval:skill-inject": "node scripts/eval-skill-inject.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.16.0",
    "husky": "^9.1.7",
    "js-yaml": "4.3.0",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@cloudbase/manager-node": "^5.6.1"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.3.0",
      "brace-expansion@1": "1.1.16",
      "brace-expansion@2": "2.1.2",
      "brace-expansion@3": "5.0.7",
      "brace-expansion@4": "5.0.7",
      "brace-expansion@5": "5.0.7"
    }
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "brace-expansion@1": "1.1.16",
    "brace-expansion@2": "2.1.2",
    "brace-expansion@3": "5.0.7",
    "brace-expansion@4": "5.0.7",
    "brace-expansion@5": "5.0.7"
  }
}
